<!DOCTYPE html>
<html lang="id">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title><%= appName %></title>
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
      rel="stylesheet"
    />
    <link rel="stylesheet" href="/assets/css/style.css" />
  </head>
  <body class="bg-body-tertiary">
    <nav class="navbar navbar-expand-lg bg-dark navbar-dark shadow-sm">
      <div class="container">
        <a class="navbar-brand fw-bold" href="/inbox"><%= appName %></a>
        <div class="d-flex align-items-center gap-2">
          <a href="/inbox" class="btn btn-outline-light btn-sm">Inbox</a>
          <a href="/sent" class="btn btn-outline-light btn-sm">Terkirim</a>
          <a href="/trash" class="btn btn-outline-light btn-sm">Trash</a>
          <a href="/compose" class="btn btn-primary btn-sm">Tulis Pesan</a>
        </div>
      </div>
    </nav>

    <main class="container py-4">
      <div class="card border-0 shadow-sm mb-3">
        <div class="card-body d-flex flex-wrap align-items-center justify-content-between gap-3">
          <div>
            <h6 class="mb-1">Mailbox Aktif</h6>
            <span class="badge text-bg-primary fs-6"><%= currentUser %></span>
          </div>
          <form action="/switch-user" method="post" class="d-flex gap-2">
            <input
              class="form-control"
              type="text"
              name="user"
              placeholder="contoh: support atau support@<%= domain %>"
              required
            />
            <button class="btn btn-dark" type="submit">Ganti</button>
          </form>
        </div>
      </div>
