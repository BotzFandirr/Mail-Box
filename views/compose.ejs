<%- include('partials/header') %>

<section class="card border-0 shadow-sm">
  <div class="card-header bg-white py-3">
    <h5 class="mb-0">Tulis Pesan Baru</h5>
  </div>
  <div class="card-body">
    <form action="/messages" method="post" class="row g-3">
      <div class="col-md-6">
        <label class="form-label">Dari</label>
        <input class="form-control" value="<%= currentUser %>" disabled />
      </div>
      <div class="col-md-6">
        <label class="form-label">Kepada</label>
        <input
          class="form-control"
          name="to"
          placeholder="contoh: sales atau sales@<%= domain %>"
          required
        />
      </div>
      <div class="col-12">
        <label class="form-label">Subjek</label>
        <input class="form-control" name="subject" placeholder="Masukkan subjek pesan" />
      </div>
      <div class="col-12">
        <label class="form-label">Isi Pesan</label>
        <textarea class="form-control" name="body" rows="8" placeholder="Tulis pesan Anda di sini" required></textarea>
      </div>
      <div class="col-12 d-flex justify-content-end gap-2">
        <a href="/inbox" class="btn btn-outline-secondary">Batal</a>
        <button class="btn btn-primary px-4" type="submit">Kirim</button>
      </div>
    </form>
  </div>
</section>

<%- include('partials/footer') %>
